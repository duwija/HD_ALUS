<?php

// ZTE OID Configuration - Auto Load based on OLT Model
// This file will load appropriate OID config based on OLT type
// Default: C300/C320 series

// Function to get OID config based on OLT object
if (!function_exists('get_olt_oid_config')) {
    function get_olt_oid_config($olt = null) {
        // If no OLT object, return default C300 config
        if (!$olt) {
            return config('zteoid'); // Current file
        }

        // Get OLT model/version from name or type
        $oltModel = strtolower($olt->name ?? '');
        $oltType = strtolower($olt->type ?? '');
        $oltVendor = strtolower($olt->vendor ?? '');
        
        // Detect vendor first
        // CDATA OLT detection
        if (
            str_contains($oltVendor, 'cdata') ||
            str_contains($oltModel, 'cdata') ||
            str_contains($oltType, 'cdata') ||
            str_contains($oltModel, 'fdd-lt') || // CDATA GPON
            str_contains($oltModel, 'fdd-olt') ||
            str_contains($oltType, 'fdd')
        ) {
            return config('cdata_oid');
        }
        
        // HSGQ OLT detection
        if (
            str_contains($oltVendor, 'hsgq') ||
            str_contains($oltModel, 'hsgq') ||
            str_contains($oltType, 'hsgq')
        ) {
            return config('hsgq_oid');
        }
        
        // Huawei OLT detection
        if (
            str_contains($oltVendor, 'huawei') ||
            str_contains($oltModel, 'huawei') ||
            str_contains($oltModel, 'ma5') || // Huawei MA5600/MA5800
            str_contains($oltType, 'huawei')
        ) {
            return config('huawei_oid');
        }
        
        // Fiberhome OLT detection
        if (
            str_contains($oltVendor, 'fiberhome') ||
            str_contains($oltModel, 'fiberhome') ||
            str_contains($oltModel, 'an5') || // Fiberhome AN5xxx
            str_contains($oltType, 'fiberhome')
        ) {
            return config('fiberhome_oid');
        }
        
        // ZTE OLT series detection
        // ZTE C600/C620/C650 series
        if (
            str_contains($oltModel, 'c600') || 
            str_contains($oltModel, 'c620') || 
            str_contains($oltModel, 'c650') ||
            str_contains($oltType, 'c600') ||
            str_contains($oltType, 'c620') ||
            str_contains($oltType, 'c650') ||
            str_contains($oltType, 'zte-c600')
        ) {
            return config('zte_c600_oid');
        }
        
        // Default to ZTE C300/C320 series (this file)
        return config('zteoid');
    }
}

