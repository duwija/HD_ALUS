// Function to get ONU status config based on OLT object
if (!function_exists('get_olt_status_config')) {
    function get_olt_status_config($olt = null) {
        // If no OLT object, return default
        if (!$olt) {
            return config('zteontstatus');
        }

        // Get OLT model/version
        $oltModel = strtolower($olt->name ?? '');
        $oltType = strtolower($olt->type ?? '');
        $oltVendor = strtolower($olt->vendor ?? '');
        
        // CDATA status mapping
        if (
            str_contains($oltVendor, 'cdata') ||
            str_contains($oltModel, 'cdata') ||
            str_contains($oltType, 'cdata') ||
            str_contains($oltModel, 'fdd')
        ) {
            return config('cdata_onustatus');
        }
        
        // HSGQ status mapping
        if (
            str_contains($oltVendor, 'hsgq') ||
            str_contains($oltModel, 'hsgq') ||
            str_contains($oltType, 'hsgq')
        ) {
            return config('hsgq_onustatus');
        }
        
        // Huawei status mapping
        if (
            str_contains($oltVendor, 'huawei') ||
            str_contains($oltModel, 'huawei') ||
            str_contains($oltModel, 'ma5')
        ) {
            return config('huawei_onustatus');
        }
        
        // ZTE C600 series
        if (
            str_contains($oltModel, 'c600') || 
            str_contains($oltModel, 'c620') || 
            str_contains($oltModel, 'c650') ||
            str_contains($oltType, 'c600') ||
            str_contains($oltType, 'c620') ||
            str_contains($oltType, 'c650')
        ) {
            return config('zte_c600_ontstatus');
        }
        
        // Default to ZTE C300/C320
        return config('zteontstatus');
    }
}

// Function to get ONU status config based on OLT object
if (!function_exists('get_olt_status_config')) {
    function get_olt_status_config($olt = null) {
        // If no OLT object, return default
        if (!$olt) {
            return config('zteontstatus');
        }

        // Get OLT model/version
        $oltModel = strtolower($olt->name ?? '');
        $oltType = strtolower($olt->type ?? '');
        
        // Detect OLT series
        if (
            str_contains($oltModel, 'c600') || 
            str_contains($oltModel, 'c620') || 
            str_contains($oltModel, 'c650') ||
            str_contains($oltType, 'c600') ||
            str_contains($oltType, 'c620') ||
            str_contains($oltType, 'c650')
        ) {
            return config('zte_c600_ontstatus');
        }
        
        // Default
        return config('zteontstatus');
    }
}

