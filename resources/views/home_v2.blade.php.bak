@section('footer-scripts')
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  const isDark         = () => document.body.classList.contains('dark-mode');
  const chartTextColor = () => isDark() ? '#9ba3b2' : '#6b7280';
  const chartGridColor = () => isDark() ? '#333845' : '#e5e7eb';

  // Live clock
  (function tick() {
    const el = document.getElementById('live-clock');
    if (el) el.textContent = new Date().toLocaleTimeString('id-ID', { hour:'2-digit', minute:'2-digit', second:'2-digit' });
    setTimeout(tick, 1000);
  })();

  // Mini bar chart — 7 hari terakhir
  const histChart = new Chart(document.getElementById('myHistoryChart'), {
    type: 'bar',
    data: {
      labels: {!! json_encode($historyDates) !!},
      datasets: [{
        label: 'Tiket',
        data: {!! json_encode($historyTotals) !!},
        backgroundColor: 'rgba(30,136,229,.65)',
        borderColor: 'rgba(30,136,229,1)',
        borderWidth: 1,
        borderRadius: 4,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false }, tooltip: { mode: 'index' } },
      scales: {
        x: { grid: { display: false }, ticks: { color: chartTextColor(), font: { size: 10 } } },
        y: { beginAtZero: true, ticks: { color: chartTextColor(), font: { size: 10 }, stepSize: 1 }, grid: { color: chartGridColor() } }
      }
    }
  });

  // Customer Baru chart — id_status=2 (Active) by billing_start
  new Chart(document.getElementById('custNewChart'), {
    type: 'bar',
    data: {
      labels: {!! json_encode($custMonthLabels) !!},
      datasets: [{
        label: 'Customer Baru (Active)',
        data: {!! json_encode($custNewMonthly) !!},
        backgroundColor: 'rgba(67,160,71,.75)',
        borderColor: '#43a047',
        borderWidth: 1,
        borderRadius: 4,
        yAxisID: 'y',
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          mode: 'index',
          callbacks: { title: ctx => ctx[0].label + ' — Customer Baru' }
        }
      },
      scales: {
        x: { grid: { display: false }, ticks: { color: chartTextColor(), font: { size: 10 } } },
        y: { beginAtZero: true, ticks: { color: chartTextColor(), font: { size: 10 }, stepSize: 1 }, grid: { color: chartGridColor() } }
      }
    }
  });

  // Customer Terminate chart — Block (id_status=4) + Inactive (id_status=3) by updated_at
  new Chart(document.getElementById('custBlockChart'), {
    type: 'bar',
    data: {
      labels: {!! json_encode($custMonthLabels) !!},
      datasets: [
        {
          label: 'Deleted',
          data: {!! json_encode($custBlockMonthly) !!},
          backgroundColor: 'rgba(229,57,53,.75)',
          borderColor: '#e53935',
          borderWidth: 1,
          borderRadius: 4,
        },
        {
          label: 'Inactive',
          data: {!! json_encode($custInactiveMonthly) !!},
          backgroundColor: 'rgba(251,140,0,.75)',
          borderColor: '#fb8c00',
          borderWidth: 1,
          borderRadius: 4,
        }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: {
          display: true,
          position: 'top',
          labels: { color: chartTextColor(), font: { size: 10 }, boxWidth: 12, padding: 8 }
        },
        tooltip: { mode: 'index' }
      },
      scales: {
        x: { stacked: true, grid: { display: false }, ticks: { color: chartTextColor(), font: { size: 10 } } },
        y: { stacked: true, beginAtZero: true, ticks: { color: chartTextColor(), font: { size: 10 }, stepSize: 1 }, grid: { color: chartGridColor() } }
      }
    }
  });

  const dmBtn = document.getElementById('toggleDarkMode');
  if (dmBtn) dmBtn.addEventListener('click', () => {
    setTimeout(() => {
      histChart.options.scales.x.ticks.color = chartTextColor();
      histChart.options.scales.y.ticks.color = chartTextColor();
      histChart.options.scales.y.grid.color  = chartGridColor();
      histChart.update();
    }, 50);
  });

  $(function(){ $('[data-toggle="tooltip"]').tooltip({ delay: { show:300, hide:150 } }); });
</script>
@endsection
