<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Network Monitoring Realtime</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" rel="stylesheet">
  <style>
    .sparkline { height: 40px !important; }
    .offline-glow { box-shadow: 0 0 12px 2px rgba(239, 68, 68, 0.7); }
    .down-glow { box-shadow: 0 0 10px 2px rgba(234, 179, 8, 0.6); }
  </style>
</head>
<body class="bg-gray-900 text-gray-100 font-sans">
  <div class="p-4">
    <h1 class="text-3xl font-bold mb-4 animate__animated animate__fadeInDown bg-gradient-to-r from-green-400 via-blue-500 to-purple-600 bg-clip-text text-transparent">
      🌐 Network Monitoring Dashboard
    </h1>
    <p class="text-gray-400 mb-4">Live update setiap 10 detik</p>

    <!-- Filter Buttons -->
    <div class="flex flex-wrap gap-2 mb-4 text-sm">
      <button class="filter-btn bg-blue-600 px-2 py-1 rounded" data-filter="all">All</button>
      <button class="filter-btn bg-red-600 px-2 py-1 rounded" data-filter="offline">Offline</button>
      <button class="filter-btn bg-yellow-500 px-2 py-1 rounded" data-filter="down">Down</button>
      <button class="filter-btn bg-green-600 px-2 py-1 rounded" data-filter="online">Online</button>
    </div>

    <div id="stats" class="text-sm mb-4"></div>
    <div id="probeTable" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 xl:grid-cols-8 gap-3"></div>
  </div>

  <script>
    const historyData = {};
    let currentFilter = 'all';

    async function loadProbeData() {
      const res = await fetch('/api/probe/status');
      const data = await res.json();

      // 🔹 Urutkan data: Offline > Down > Online
      data.sort((a, b) => {
        if (a.probe_status === 'offline' && b.probe_status !== 'offline') return -1;
        if (b.probe_status === 'offline' && a.probe_status !== 'offline') return 1;
        if (!a.is_up && b.is_up) return -1;
        if (!b.is_up && a.is_up) return 1;
        return 0;
      });

      // 🔹 Filter sesuai pilihan user
      const filteredData = data.filter(p => {
        if (currentFilter === 'offline') return p.probe_status === 'offline';
        if (currentFilter === 'down') return p.probe_status !== 'offline' && !p.is_up;
        if (currentFilter === 'online') return p.probe_status !== 'offline' && p.is_up;
        return true;
      });

      // 🔹 Statistik total
      const total = data.length;
      const offline = data.filter(p => p.probe_status === 'offline').length;
      const down = data.filter(p => !p.is_up && p.probe_status !== 'offline').length;
      document.getElementById('stats').innerHTML = `
      <span class="text-green-400">Online: ${total - down - offline}</span> |
      <span class="text-yellow-400">Down: ${down}</span> |
      <span class="text-red-400">Offline: ${offline}</span> |
      <span class="text-gray-400">Total: ${total}</span>
      `;

      const container = document.getElementById('probeTable');
      container.innerHTML = '';

      filteredData.forEach(p => {
        const key = `${p.probe_id}_${p.host}`;
        if (!historyData[key]) historyData[key] = [];
        historyData[key].push(p.rtt_avg_ms || 0);
        if (historyData[key].length > 10) historyData[key].shift();

        const color = p.is_up ? 'green' : 'red';
        const pulse = p.probe_status === 'offline' ? 'animate-pulse bg-red-700' : 'bg-gray-800';
        const probeStatus = p.probe_status === 'offline'
        ? 'Offline'
        : (p.is_up ? 'Online' : 'Down');
        const barWidth = Math.min(p.rtt_avg_ms || 0, 200) / 2;
        let glowClass = '';
        if (p.probe_status === 'offline') glowClass = 'offline-glow';
        else if (!p.is_up) glowClass = 'down-glow';

        const card = document.createElement('div');
        card.className = `p-2 rounded-lg shadow border border-gray-700 transition transform hover:scale-105 ${pulse} ${glowClass}`;
        card.innerHTML = `
        <div class="flex justify-between items-center text-xs mb-1">
        <span class="font-semibold">${p.probe_id ?? 'Probe'}</span>
        <span class="px-1 rounded bg-${color}-700">${probeStatus}</span>
        </div>
        <div class="text-[10px] text-gray-400 mb-1 truncate">${p.host}</div>
        <div class="w-full bg-gray-700 h-1 rounded mb-1">
        <div class="h-1 bg-${color}-500 rounded" style="width:${barWidth}%"></div>
        </div>
        <div class="text-[10px] text-gray-400">RTT: ${p.rtt_avg_ms ?? 0} ms</div>
        <canvas id="chart_${key.replace(/[.:]/g,'_')}" class="sparkline mt-1"></canvas>
        <div class="text-[9px] text-gray-500 mt-1">Last: ${new Date(p.polled_at).toLocaleTimeString()}</div>
        `;
        container.appendChild(card);

        const ctx = card.querySelector('canvas').getContext('2d');
        new Chart(ctx, {
          type: 'line',
          data: {
            labels: Array.from({length: historyData[key].length}, (_, i) => i + 1),
            datasets: [{
              data: historyData[key],
              borderColor: p.is_up ? '#10B981' : '#EF4444',
              tension: 0.3,
              fill: false,
              pointRadius: 0,
              borderWidth: 1.2
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: { x: {display: false}, y: {display: false} },
            plugins: {legend: {display: false}}
          }
        });
      });
    }

    // 🔁 Refresh data otomatis setiap 10 detik
    loadProbeData();
    setInterval(loadProbeData, 10000);

    // 🔘 Filter tombol event
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', e => {
        currentFilter = btn.getAttribute('data-filter');
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('ring-2', 'ring-white'));
        btn.classList.add('ring-2', 'ring-white');
        loadProbeData();
      });
    });
  </script>
</body>
</html>
