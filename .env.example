# =============================================================================
#  .env.example — Template konfigurasi untuk server baru
#  JANGAN isi nilai asli di sini. Copy ke .env lalu isi per-server.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="ISP Billing"
APP_ENV=production
APP_KEY=                          # generate: php artisan key:generate
APP_DEBUG=false
APP_URL=https://namaserver.alus.co.id
SIGNATURE="Terima Kasih"

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=daily

# ── Database (tenant DB lokal) ───────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nama_db_tenant
DB_USERNAME=db_user
DB_PASSWORD=

# ── Database (master / isp_master) ──────────────────────────────────────────
MASTER_DB_HOST=127.0.0.1
MASTER_DB_PORT=3306
MASTER_DB_DATABASE=isp_master
MASTER_DB_USERNAME=db_user
MASTER_DB_PASSWORD=

# ── Database (admin DB) ──────────────────────────────────────────────────────
ADMIN_DB_HOST=127.0.0.1
ADMIN_DB_PORT=3306
ADMIN_DB_DATABASE=admin_db
ADMIN_DB_USERNAME=db_user
ADMIN_DB_PASSWORD=

# ── Cache / Session / Queue ──────────────────────────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# ── Perusahaan / Tenant ──────────────────────────────────────────────────────
COMPANY_NAME="Nama Perusahaan"
COMPANY=
COMPANY_ADDRESS1="Jl. Contoh No. 1"
COMPANY_ADDRESS2="Kota, Provinsi"
DOMAIN_NAME=namaserver.alus.co.id
INV_NOTE="Catatan invoice"

# ── Peta ─────────────────────────────────────────────────────────────────────
COORDINATE_CENTER="-6.2,106.8"
COORDINATE_ZOOM=13

# ── Akuntansi ────────────────────────────────────────────────────────────────
DEVIDEN_ID=
IKHTISAR_LABA_RUGI_ID=
MODAL_ID=
RESCODE=

# ── WhatsApp Gateway ─────────────────────────────────────────────────────────
# Pilih satu provider: gateway | wapisender | qontak
WA_PROVIDER=gateway
WA_GATEWAY_URL=https://wa.example.com
WA_CHANNEL_INTEGRATION_ID=

WAPISENDER_SEND_MESSAGE=https://api.wapisender.com/api/v5/message/send
WAPISENDER_STATUS=https://api.wapisender.com/api/v5/device/status
WAPISENDER_QR=https://api.wapisender.com/api/v5/device/qr
WAPISENDER_RESTART=https://api.wapisender.com/api/v5/device/restart
WAPISENDER_USER=
WAPISENDER_DEVICE=
WAPISENDER_INFO=
WAPISENDER_GROUPPAYMENT=
WAPISENDER_GROUPTICKET=

WHATSAPP_API_URL=
WA_TAMPLATE_ID_1=
WA_TAMPLATE_ID_2=
WA_TAMPLATE_ID_3=

# Grup WA notifikasi
WA_GROUP_PAYMENT=
WA_GROUP_SUPPORT=
WA_GROUP_VENDOR=
PAYMENT_WA=

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_GROUP_PAYMENT=
TELEGRAM_GROUP_SUPPORT=

# ── Payment Gateway — Tripay ─────────────────────────────────────────────────
TRIPAY_ENDPOINT=https://tripay.co.id/api/transaction/create
TRIPAY_MERCHANTCODE=
TRIPAY_APIKEY=
TRIPAY_PRIVATEKEY=

# ── Payment Gateway — Duitku ─────────────────────────────────────────────────
DUITKU_MERCHANT_CODE=
DUITKU_API_KEY=
DUITKU_SANDBOX=false

# ── Payment Gateway — Winpay ─────────────────────────────────────────────────
WINPAY_ENDPOINT=https://api.winpay.id
WINPAY_KEY=
WINPAY_SECRET=

# ── FCM / Firebase ───────────────────────────────────────────────────────────
FCM_PROJECT_ID=
FIREBASE_CREDENTIALS=

# ── Python (Telegram bot) ────────────────────────────────────────────────────
PHYTON_DIR=/var/www/python/

# ── Misc ─────────────────────────────────────────────────────────────────────
XENDIT_FEE=2500
FTP_USER=

# ── Pusher (jika pakai) ──────────────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
